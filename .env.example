# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=techwholesale

# Server Configuration
NODE_ENV=production
PORT=5000
API_URL=http://localhost:5000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Frontend Configuration
NEXT_PUBLIC_API_URL=https://your-api-domain.com
NEXT_PUBLIC_APP_URL=https://your-app-domain.com

# Hostinger Deployment
HOSTINGER_APP_URL=https://your-hostinger-domain.com
HOSTINGER_MYSQL_HOST=your-hostinger-mysql-host
HOSTINGER_MYSQL_USER=your-hostinger-mysql-user
HOSTINGER_MYSQL_PASSWORD=your-hostinger-mysql-password
HOSTINGER_MYSQL_DB=your-hostinger-database

# Payment Configuration (Mock)
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@techwholesale.com

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
