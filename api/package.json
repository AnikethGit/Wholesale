{
  "name": "bestwholesale-api",
  "version": "1.0.0",
  "description": "BestWholesale E-commerce API - Node.js & Express",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node scripts/seedDatabase.js",
    "migrate": "node scripts/migrate.js",
    "test": "jest --passWithNoTests",
    "test:auth": "jest src/__tests__/auth.test.js",
    "test:checkout": "jest src/__tests__/checkout.test.js",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.js'"
  },
  "keywords": [
    "ecommerce",
    "api",
    "express",
    "nodejs"
  ],
  "author": "BestWholesale",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "next": "16.2.4",
    "nodemailer": "^8.0.5",
    "stripe": "^14.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.53.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
